msgid "emails.statisticsReportNotification.subject"
msgstr "Urednička aktivnost za {$month}, {$year}"

msgid "emails.statisticsReportNotification.body"
msgstr ""
"\n"
"{$recipientName}, <br />\n"
"<br />\n"
"Vaš izveštaj o stanju časopisa za {$month}, {$year} je sada dostupan. "
"Ključne statistike za ovaj mesec su navedene ispod.<br />\n"
"<ul> <li>Novi radovi ovog meseca: {$newSubmissions}</li> \n"
"<li>Odbijeni radovi ovog meseca: {$declinedSubmissions}</li> \n"
"<li>Prihvaćeni radovi ovog meseca: {$acceptedSubmissions}</li> \n"
"<li>Ukupan broj radova u sistemu: {$totalSubmissions}</li> \n"
"</ul> Prijavite se u časopis da biste videli detaljnije <a href=\""
"{$editorialStatsLink}\">uredničke trendove</a> i <a href=\""
"{$publicationStatsLink}\">statistiku objavljenih članaka</a>. Kompletna "
"kopija ovog mesečnog izveštaja o uredničkim trendovima je priložena.<br />\n"
" <br /> Srdačno,<br /> {$contextSignature}"

