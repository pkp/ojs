msgstr "Þörf er á vefslóð."

msgid "admin.contexts.form.pathAlphaNumeric"
msgstr ""
"Slóðin má aðeins innihalda bókstafi, tölur og táknin _ og -. Hún verður að "
"byrja og enda á bókstaf eða tölu."

msgid "admin.contexts.form.pathExists"
msgstr "Slóðin sem þú gafst upp er nú þegar í notkun hjá öðru tímariti."

msgid "admin.contexts.form.primaryLocaleNotSupported"
msgstr ""
"Aðaltungumálastaðfærslan verður að vera ein af studdum staðfærslum "
"tímaritsins."

