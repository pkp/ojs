msgid "userInvitation.sendMail.stepDescription"
msgstr ""
"Хэрэглэгчид урилга, дараагийн алхмууд, сэтгүүлийн GDPR нууцлалын бодлого "
"болон ORCID баталгаажуулалтын талаар мэдэгдэх имэйл илгээнэ үү"

msgid "acceptInvitation.accountDetails.stepDescription"
msgstr ""
"OJS системийг ашиглаж эхлэх болон шинэ үүргийг хүлээн авахын тулд та манай "
"системд бүртгэл үүсгэх шаардлагатай. Үүний тулд нэвтрэх нэр болон нууц үгээ "
"оруулна уу."

msgid "acceptInvitation.accountDetails.stepLabel"
msgstr "{$step} - OJS бүртгэл үүсгэх"

msgid "acceptInvitation.accountDetails.stepName"
msgstr "OJS бүртгэл үүсгэх"

msgid "acceptInvitation.detailsReview.nextButtonLabel"
msgstr "Зөвшөөрөх ба OJS руу үргэлжлүүлэх"

msgid "acceptInvitation.detailsReview.stepDescription"
msgstr "OJS систем дэх шинэ үүргээ эхлүүлэхийн тулд мэдээллээ хянана уу"

msgid "acceptInvitation.modal.message"
msgstr ""
"OJS системд шинэ үүрэг авсанд тань баяр хүргэе! Та одоо шинэ тохиргоо, "
"сонголтуудад хандах эрхтэй болж магадгүй. Хэрэв танд системийг ойлгоход "
"тусламж хэрэгтэй бол систем дэх “Тусламж” (Help) товчийг дарж зааварчилгаа "
"авна уу."

msgid "acceptInvitation.modal.title"
msgstr "Танд OJS системд шинэ үүрэг оноолоо"

msgid "invitation.role.masthead"
msgstr "Сэтгүүлийн бүрэлдэхүүн (Masthead)"

msgid "invitation.wizard.pageTitleDescription"
msgstr ""
"Та хэрэглэгчийг OJS системд үүрэг гүйцэтгэх болон сэтгүүлийн бүрэлдэхүүнд "
"(masthead) нэрээ гаргахыг урьж байна"

msgid "userInvitation.enterDetails.stepDescription"
msgstr "Та тэднийг OJS системд үүрэг гүйцэтгэхийг урьж болно"

msgid "userInvitation.modal.message"
msgstr ""
"{$email} хаягт OJS системийн шинэ үүргийн урилга илгээлээ. Хэрэглэгчийн "
"шийдвэрийн талаарх мэдээллийг 'Хэрэглэгчид ба Үүрэг' хуудас, OJS мэдэгдэл "
"болон/эсвэл өөрийн имэйлээр хүлээн авах боломжтой"

msgid "userInvitation.roleTable.journalMasthead"
msgstr "Сэтгүүлийн бүрэлдэхүүн (Masthead)"

msgid "userInvitation.search.userFound"
msgstr "Хэрэглэгч энэ сэтгүүлд аль хэдийн бүртгэлтэй байна"

msgid "userInvitation.search.userNotFound"
msgstr "Энэ хэрэглэгч тус сэтгүүлд ямар нэгэн үүрэггүй байна"

msgid "userInvitation.searchUser.stepDescription"
msgstr ""
"Хэрэглэгчийг имэйл хаяг, нэвтрэх нэр эсвэл ORCID ID-аар нь хайна уу. "
"Эхлэхийн тулд дор хаяж нэг мэдээллийг оруулна уу. Хэрэв хэрэглэгч байхгүй "
"бол та тэднийг үүрэг гүйцэтгэж, сэтгүүлийнхээ нэг хэсэг болохыг урьж болно. "
"Хэрэв хэрэглэгч системд аль хэдийн бүртгэлтэй бол мэдээллийг нь үзэж, нэмэлт "
"үүрэг гүйцэтгэхийг урьж болно."

msgid "acceptInvitation.verifyOrcid.stepDescription"
msgstr ""
"Та ORCID iD-гээ баталгаажуулах эсвэл алгасахаар сонгож болно. Хэрэв одоо "
"алгасахаар сонговол дараа нь OJS систем дэх өөрийн профайл хэсгээс ORCID iD-"
"гээ баталгаажуулах боломжтой"
