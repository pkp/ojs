msgid "admin.overwriteConfigFileInstructions"
msgstr ""
"<h4>ЭСКЕРТҮҮ!</h4>\n"
"<p>Система конфигурация файлын автоматтык түрдө жаңырта алган жок. "
"Конфигурация өзгөртүүлөрүн колдонуу үчүн <tt>config.inc.php</tt> файлын "
"ылайыктуу тексттик редактордо ачып, анын мазмунун төмөнкү текст талаасындагы "
"мазмун менен алмаштырышыңыз керек.</p>"

msgid "plugins.categories.auth.description"
