msgid "plugins.importexport.users.displayName"
msgstr "Колдонуучуларды XML аркылуу импорт/экспорт кылуу плагини"

msgid "plugins.importexport.users.description"
msgstr "Колдонуучуларды импорттоо жана экспорттоо"

msgid "plugins.importexport.users.cliUsage"
msgstr ""
"Колдонуу: {$scriptName} {$pluginName} [команда] ...\n"
"Командалар:\n"
"\timport [xmlFileName] [journal_path]\n"
"\texport [xmlFileName] [journal_path]\n"
"\texport [xmlFileName] [journal_path] [userId1] [userId2] ...\n"

msgid "plugins.importexport.users.cliUsage.examples"
msgstr ""
"\n"
"Мисалдар:\n"
"\tКолдонуучуларды myImportFile.xml файлы аркылуу myJournal журналына "
"импорттоо:\n"
"\t{$scriptName} {$pluginName} import myImportFile.xml myJournal\n"
"\n"
"\tБардык колдонуучуларды myJournal журналынан экспорттоо:\n"
"\t{$scriptName} {$pluginName} export myExportFile.xml myJournal\n"
"\n"
"\tID боюнча көрсөтүлгөн колдонуучуларды экспорттоо:\n"
"\t{$scriptName} {$pluginName} export myExportFile.xml myJournal 1 2\n"

msgid "plugins.importexport.users.import.importUsers"
msgstr "Колдонуучуларды импорттоо"

msgid "plugins.importexport.users.import.usersWereImported"
msgstr "Төмөнкү колдонуучулар системага ийгиликтүү импорттолду"

msgid "plugins.importexport.users.import.errorsOccurred"
msgstr "Импорттоо учурунда каталар пайда болду"

msgid "plugins.importexport.users.import.instructions"
msgstr ""
"Бул журналга импорттоо үчүн колдонуучу маалыматын камтыган XML файлды "
"тандаңыз. Файлдын форматы боюнча журнал жардамынан караңыз.<br /><br /"
">Эскерте кетели, эгер импорттолгон файлда системада мурунтан бар колдонуучу "
"аттары же электрондук почта даректери болсо, ал колдонуучулардын "
"маалыматтары импорттолбойт жана жаңы ролдор ошол учурдагы колдонуучуларга "
"дайындалат."

msgid "plugins.importexport.users.import.dataFile"
msgstr "Колдонуучу маалымат файлы"

msgid "plugins.importexport.users.import.sendNotify"
msgstr ""
"Импорттолгон ар бир колдонуучуга анын колдонуучу аты жана сырсөзү камтылган "
"билдирүү электрондук кат жөнөтүү."

msgid "plugins.importexport.users.import.continueOnError"
msgstr "Ката чыкса да башка колдонуучуларды импорттоону улантуу."

msgid "plugins.importexport.users.import.confirmUsers"
msgstr "Бул колдонуучуларды системага импорттоону каалаганыңызды ырастаңыз"

msgid "plugins.importexport.users.import.warning"
msgstr "Эскертүү"

msgid "plugins.importexport.users.import.encryptionMismatch"
msgstr ""
"Сырсөздөр {$importHash} менен хэштелгендиктен колдонулбайт; OJS {$ojsHash} "
"колдонууга конфигурацияланган. Эгер улантсаңыз, импорттолгон "
"колдонуучулардын сырсөздөрүн кайра коюшуңуз керек болот."

msgid "plugins.importexport.users.unknownPress"
msgstr "Белгисиз журнал жолу \"{$journalPath}\" көрсөтүлдү."

msgid "plugins.importexport.users.export.exportUsers"
msgstr "Колдонуучуларды экспорттоо"

msgid "plugins.importexport.users.export.exportByRole"
msgstr "Рол боюнча экспорттоо"

msgid "plugins.importexport.users.export.exportAllUsers"
msgstr "Бардыгын экспорттоо"

msgid "plugins.importexport.users.export.errorsOccurred"
msgstr "Экспорттоо учурунда каталар пайда болду"

msgid "plugins.importexport.users.importComplete"
msgstr ""
"Импорттоо ийгиликтүү аяктады. Колдонуучу аттары жана электрондук почта "
"даректери мурунтан колдонулбаган колдонуучулар импорттолду жана тиешелүү "
"колдонуучу топтору кошулду."

msgid "plugins.importexport.users.results"
msgstr "Жыйынтыктар"

msgid "plugins.importexport.users.uploadFile"
msgstr "\"Импорттоо\" бөлүмүнө файл жүктөп, андан кийин улантыңыз."
