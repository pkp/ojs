msgid "plugins.importexport.pubmed.displayName"
msgstr "PubMed XML útflutningsviðbót"

msgid "plugins.importexport.pubmed.description"
msgstr "Flytur út lýsigögn greina á PubMed XML-sniði fyrir skráningu í MEDLINE."

msgid "plugins.importexport.pubmed.export"
msgstr "Flytja út gögn"

msgid "plugins.importexport.pubmed.export.issues"
msgstr "Flytja út tölublöð"

msgid "plugins.importexport.pubmed.export.selectIssue"
msgstr "Velja tölublað til að flytja út."

msgid "plugins.importexport.pubmed.export.articles"
msgstr "Flytja út greinar"

msgid "plugins.importexport.pubmed.export.selectArticle"
msgstr "Velja greinar til að flytja út."

msgid "plugins.importexport.pubmed.cliUsage"
msgstr ""
"Notkun: \n"
"{$scriptName} {$pluginName} [xmlFileName] [journal_path] greinar [articleId1]"
" [articleId2] ...\n"
"{$scriptName} {$pluginName} [xmlFileName] [journal_path] tölublað [issueId]\n"

msgid "plugins.importexport.pubmed.cliError"
msgstr "VILLA:"

msgid "plugins.importexport.pubmed.export.error.issueNotFound"
msgstr "Ekkert tölublað fannst með tilgreint auðkenni \"{$issueId}\"."

msgid "plugins.importexport.pubmed.export.error.articleNotFound"
msgstr "Engin grein fannst með tilgreint auðkenni \"{$articleId}\"."

msgid "plugins.importexport.pubmed.settings.form.nlmTitle"
msgstr "Skammstöfun titils samkvæmt NLM"

msgid "plugins.importexport.pubmed.settings.form.nlmTitle.description"
msgstr ""
"NLM skammtstöfun titils tímaritsins. Ef þú þekkir ekki skammstöfunina "
"skaltu  <a href=\"https://www.ncbi.nlm.nih.gov/nlmcatalog/\">Leita í NLM "
"spjaldskránni</a>."
