msgid "plugins.importexport.native.importComplete"
msgstr "Uvoz podataka je uspešno završen. Uvezeni su sledeći podaci:"

#, fuzzy
msgid "plugins.importexport.native.cliUsage"
msgstr ""
"Korišćenje: {$scriptName} {$pluginName} [command] ...\n"
"Komande:\n"
"\timport [xmlFileName] [journal_path] [user_name] ...\n"
"\texport [xmlFileName] [journal_path] articles [articleId1] "
"[articleId2] ...\n"
"\texport [xmlFileName] [journal_path] article [articleId]\n"
"\texport [xmlFileName] [journal_path] issues [issueId1] [issueId2] ...\n"
"\texport [xmlFileName] [journal_path] issue [issueId]\n"
"\n"
"Additional parameters are required for importing data as follows, depending\n"
"on the root node of the XML document.\n"
"\n"
"If the root node is <article> or <articles>, additional parameters are "
"required.\n"
"The following formats are accepted:\n"
"\n"
"{$scriptName} {$pluginName} import [xmlFileName] [journal_path] [user_name]\n"
"\tissue_id [issueId] section_id [sectionId]\n"
"\n"
"{$scriptName} {$pluginName} import [xmlFileName] [journal_path] [user_name]\n"
"\tissue_id [issueId] section_name [name]\n"
"\n"
"{$scriptName} {$pluginName} import [xmlFileName] [journal_path]\n"
"\tissue_id [issueId] section_abbrev [abbrev]"

msgid "plugins.importexport.native.error.unknownSection"
msgstr "Nepoznata rubrika {$param}"

#, fuzzy
msgid "plugins.importexport.native.error.unknownUser"
msgstr "Navedeni korisnik, \"{$userName}\", ne postoji."

msgid "plugins.importexport.native.import.error.sectionTitleMismatch"
msgstr ""
"Naslov sekcije „{$section1Title}“ i naslov sekcije „{$section2Title}“ u "
"broju „{$issueTitle}“ odgovaraju različitim postojećim sekcijama časopisa."

msgid "plugins.importexport.native.import.error.sectionTitleMatch"
msgstr ""
"Naslov sekcije „{$sectionTitle}“ u broju „{$issueTitle}“ odgovara postojećoj "
"rubrici časopisa, ali drugi naslov ove rubrike ne odgovara drugom naslovu "
"postojeće rubrike časopisa."

msgid "plugins.importexport.native.import.error.sectionAbbrevMismatch"
msgstr ""
"Skraćenica rubrike „{$section1Abbrev}“ i skraćenica rubrike "
"„{$section2Abbrev}“ u broju „{$issueTitle}“ odgovaraju različitim postojećim "
"rubrikama časopisa."

msgid "plugins.importexport.native.import.error.sectionAbbrevMatch"
msgstr ""
"Skraćenica rubrike „{$sectionAbbrev}“ u broju „{$issueTitle}“ odgovara "
"postojećoj rubrici časopisa, ali druga skraćenica ove rubrike ne odgovara "
"drugoj skraćenici postojeće rubrike časopisa."

msgid "plugins.importexport.native.import.error.issueIdentificationMatch"
msgstr ""
"Nijedan ili više od jednog broja odgovara datoj identifikaciji broja "
"„{$issueIdentification}“."

msgid "plugins.importexport.native.import.error.issueIdentificationDuplicate"
msgstr ""
"Postojeći broj sa ID-jem {$issueId} odgovara datoj identifikaciji broja "
"„{$issueIdentification}“. Ovaj broj neće biti izmenjen, ali će članci biti "
"dodati."

msgid "plugins.importexport.native.import.error.issueIdentificationMissing"
msgstr "Nedostaje element identifikacije broja za članak „{$articleTitle}“."

msgid "plugins.importexport.native.import.error.publishedDateMissing"
msgstr ""
"Članak „{$articleTitle}“ se nalazi u broju, ali nema datum objavljivanja."

