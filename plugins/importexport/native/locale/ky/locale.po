msgid "plugins.importexport.native.import"
msgstr "Импорттоо"

msgid "plugins.importexport.native.import.instructions"
msgstr "Импорттоо үчүн XML файлды жүктөө"

msgid "plugins.importexport.native.exportSubmissionsSelect"
msgstr "Экспорттоо үчүн макалаларды тандаңыз"

msgid "plugins.importexport.native.exportSubmissions"
msgstr "Макалаларды экспорттоо"

msgid "plugins.importexport.native.exportIssues"
msgstr "Чыгарылыштарды экспорттоо"

msgid "plugins.importexport.native.results"
msgstr "Импорттоо жыйынтыктары"

msgid "plugins.importexport.native.importComplete"
msgstr "Импорттоо ийгиликтүү аяктады. Төмөнкү элементтер импорттолду:"

msgid "plugins.importexport.native.error.unknownSection"
msgstr "Белгисиз бөлүм {$param}"

msgid "plugins.importexport.common.error.coverImageNameUnspecified"
msgstr "Капкак сүрөтү аталышы көрсөтүлбөстөн кошулган."

msgid "plugins.importexport.native.import.error.sectionTitleMatch"
msgstr ""
"«{$issueTitle}» чыгарылышындагы «{$sectionTitle}» бөлүм аталышы учурдагы "
"журнал бөлүмүнө дал келди, бирок бул бөлүмдүн башка аталышы учурдагы журнал "
"бөлүмүнүн башка аталышына дал келген жок."

msgid "plugins.importexport.native.import.error.sectionAbbrevMismatch"
msgstr ""
"«{$issueTitle}» чыгарылышындагы «{$section1Abbrev}» жана «{$section2Abbrev}» "
"бөлүм кыскартуулары ар башка учурдагы журнал бөлүмдөрүнө дал келди."

msgid "plugins.importexport.native.import.error.issueIdentificationMatch"
msgstr ""
"Берилген чыгарылыш идентификациясы «{$issueIdentification}» боюнча эч кандай "
"же бир нече чыгарылыш дал келди."

msgid "plugins.importexport.native.import.error.issueIdentificationDuplicate"
msgstr ""
"ID {$issueId} менен учурдагы чыгарылыш берилген чыгарылыш идентификациясына "
"«{$issueIdentification}» дал келди. Бул чыгарылыш өзгөртүлбөйт, бирок "
"макалалар кошулат."

msgid "plugins.importexport.native.import.error.issueIdentificationMissing"
msgstr ""
"«{$articleTitle}» макаласы үчүн чыгарылыш идентификация элементтери жок."

msgid "plugins.importexport.native.import.error.publishedDateMissing"
msgstr ""
"«{$articleTitle}» макаласы чыгарылыштын ичинде камтылган, бирок жарыяланган "
"датасы жок."

msgid "plugins.importexport.native.displayName"
msgstr "Native XML плагини"

msgid "plugins.importexport.native.description"
msgstr ""
"Макалаларды жана чыгарылыштарды OJSтин өз XML форматында импорттоо жана "
"экспорттоо."

msgid "plugins.inportexport.native.uploadFile"
msgstr "\"Импорттоо\" бөлүмүнө файл жүктөп, андан кийин улантыңыз."

msgid "plugins.importexport.common.error.invalidFileExtension"
msgstr "Капкак сүрөтү жараксыз файл кеңейтүүсү менен көрсөтүлгөн."

msgid "plugins.importexport.native.error.unknownUser"
msgstr ""
"Колдонуучу --user_name же -u команда параметри аркылуу көрсөтүлүшү керек."

msgid "plugins.importexport.native.import.error.sectionTitleMismatch"
msgstr ""
"«{$issueTitle}» чыгарылышындагы «{$section1Title}» жана «{$section2Title}» "
"бөлүм аталыштары ар башка учурдагы журнал бөлүмдөрүнө дал келди."

msgid "plugins.importexport.native.import.error.sectionAbbrevMatch"
msgstr ""
"«{$issueTitle}» чыгарылышындагы «{$sectionAbbrev}» бөлүм кыскартуусу "
"учурдагы журнал бөлүмүнө дал келди, бирок бул бөлүмдүн башка кыскартуусу "
"учурдагы журнал бөлүмүнүн башка кыскартуусуна дал келген жок."

msgid "plugins.importexport.native.cliUsage"
msgstr ""
"Колдонуу: {$scriptName} {$pluginName} [команда] ...\n"
"Командалар:\n"
"\timport [xmlFileName] [journal_path] [--user_name] ...\n"
"\texport [xmlFileName] [journal_path] articles [articleId1] [articleId2] ..."
"\n"
"\texport [xmlFileName] [journal_path] article [articleId]\n"
"\texport [xmlFileName] [journal_path] issues [issueId1] [issueId2] ...\n"
"\texport [xmlFileName] [journal_path] issue [issueId]\n"
"\n"
"Кошумча параметрлер XML документтин түпкү түйүнүнө жараша талап кылынат.\n"
"\n"
"Эгерде түпкү түйүн <article> же <articles> болсо, кошумча параметрлер талап "
"кылынат.\n"
"Төмөнкү форматтар кабыл алынат:\n"
"\n"
"{$scriptName} {$pluginName} import [xmlFileName] [journal_path] [--user_name]"
"\n"
"\tissue_id [issueId] section_id [sectionId]\n"
"\n"
"{$scriptName} {$pluginName} import [xmlFileName] [journal_path] [--user_name]"
"\n"
"\tissue_id [issueId] section_name [name]\n"
"\n"
"{$scriptName} {$pluginName} import [xmlFileName] [journal_path]\n"
"\tissue_id [issueId] section_abbrev [abbrev]\n"
