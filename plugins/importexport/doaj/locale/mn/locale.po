msgid "plugins.importexport.doaj.displayName"
msgstr "DOAJ экспорт нэмэгдэл (Plugin)"

msgid "plugins.importexport.doaj.description"
msgstr "Сэтгүүлийг DOAJ-д зориулан экспортлох."

msgid "plugins.importexport.doaj.export.contact"
msgstr "Бүртгүүлэх талаар DOAJ-тай холбоо барих"

msgid "plugins.importexport.doaj.registrationIntro"
msgstr ""
"Хэрэв та OJS систем дотроос өгүүлэл бүртгэхийг хүсвэл өөрийн DOAJ API "
"түлхүүрийг оруулна уу. Үгүй бол та өгүүллүүдийг DOAJ XML форматаар "
"экспортлох боломжтой хэвээр байх боловч OJS дотроос DOAJ-д шууд бүртгэх "
"боломжгүй болно."

msgid "plugins.importexport.doaj.settings.form.apiKey"
msgstr "DOAJ API түлхүүр"

msgid "plugins.importexport.doaj.settings.form.apiKey.description"
msgstr "Та өөрийн API түлхүүрийг DOAJ хэрэглэгчийн хуудаснаасаа олох боломжтой."

msgid ""
"plugins.importexport.doaj.settings.form.automaticRegistration.description"
msgstr ""
"OJS нь өгүүллүүдийг DOAJ руу автоматаар илгээх болно. Нийтлэгдсэний дараа "
"боловсруулахад бага зэрэг хугацаа шаардагдаж болохыг анхаарна уу (жишээ нь: "
"таны cronjob тохиргооноос хамаарч). Та бүртгэгдээгүй бүх өгүүллүүдийг шалгах "
"боломжтой."

msgid "plugins.importexport.doaj.senderTask.name"
msgstr "DOAJ автомат бүртгэлийн даалгавар"

msgid "plugins.importexport.doaj.register.error.mdsError"
msgstr "Илгээлт амжилтгүй боллоо! DOAJ API алдаа буцаалаа: '{$param}'."

msgid "plugins.importexport.doaj.cliUsage"
msgstr ""
"Ашиглах заавар:\n"
"{$scriptName} {$pluginName} export [xmlFileName] [journal_path] articles "
"objectId1 [objectId2] ...\n"
