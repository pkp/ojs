msgid "plugins.importexport.doaj.displayName"
msgstr "Útflutningsviðbót fyrir DOAJ"

msgid "plugins.importexport.doaj.description"
msgstr "Flytja út tímarit fyrir DOAJ."

msgid "plugins.importexport.doaj.export.contact"
msgstr "Hafa samband við DOAJ vegna skráningar"

msgid "plugins.importexport.doaj.registrationIntro"
msgstr ""
"Ef þú vilt skrá greinar beint úr OJS skaltu slá inn DOAJ API-lykilinn þinn. "
"Annars geturðu áfram flutt gögn út á DOAJ XML-sniði, en þú munt ekki geta "
"skráð greinar hjá DOAJ beint úr OJS."

msgid "plugins.importexport.doaj.settings.form.apiKey"
msgstr "DOAJ API lykill"

msgid "plugins.importexport.doaj.settings.form.apiKey.description"
msgstr "Þú finnur API lykilinn á DOAJ notendasíðunni þinni."

msgid ""
"plugins.importexport.doaj.settings.form.automaticRegistration.description"
msgstr ""
"OJS mun sjálfkrafa senda greinar til DOAJ. Athugaðu að það getur tekið "
"stuttan tíma eftir birtingu að vinna úr skráningunni (t.d. byggt á hvernig "
"uppsetningin er á cronjob). Þú getur leitað að öllum greinum sem enn hafa "
"ekki verið skráðar."

msgid "plugins.importexport.doaj.senderTask.name"
msgstr "Sjáflvirk skráningarverk fyrir DOAJ"

msgid "plugins.importexport.doaj.register.error.mdsError"
msgstr "Innsending mistókst! DOAJ API skilaði villu:'{$param}'."

msgid "plugins.importexport.doaj.cliUsage"
msgstr ""
"Notkun:\n"
"{$scriptName} {$pluginName} export [xmlFileName] [journal_path] articles "
"objectId1 [objectId2] ...\n"
