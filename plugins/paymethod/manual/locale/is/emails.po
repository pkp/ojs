msgid "emails.manualPaymentNotification.subject"
msgstr "Tilkynning um handvirka greiðslu"

msgid "emails.manualPaymentNotification.body"
msgstr ""
"Það þarf að afgreiða handvirka greiðslu fyrir tímaritið {$contextName} og "
"notandann &quot;{$senderUsername}&quot;.<br />\n"
"<br />\n"
"Greitt er fyrir &quot;{$paymentName}&quot;.<br />\n"
"Kostnaðurinn er {$paymentAmount} ({$paymentCurrencyCode}).<br />\n"
"<br />\n"
"Þessi tölvupóstur á uppruna sinn í Open Journal Systems viðbót fyrir "
"handvirka greiðslu."

msgid "emails.manualPaymentNotification.description"
msgstr ""
"Þessi tölvupóstur er notaður til að láta tengilið umsjónarmanns tímarits "
"vita að óskað var eftir handvirkri greiðslu."

msgid "emailTemplate.variable.manualPaymentPlugin.senderUsername"
msgstr "Notendanafn þess sem framkvæmdi greiðsluna"
