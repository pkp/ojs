# Copy this file to .env.playwright and adjust values for your local
# environment. .env.playwright is gitignored.
#
# Only values that vary between developer setups live here. Mode
# switches like APPLICATION_ENV are hardcoded by Playwright, not set
# here — you should not need to touch them.

# Where the test server listens and tests connect.
PLAYWRIGHT_BASE_URL=http://127.0.0.1:8000

# Database — must exist and be empty. tools/installTest.php creates the
# schema. Keep the name distinct from your Cypress DB (cypress.env.json
# uses ojs_main_test) so the two suites can coexist.
#
# IMPORTANT: bootstrap.setup.js seeds an `admin` / `admin` login on this
# database (matches the Cypress baseline). Point OJS_DB_HOST at a local
# DB only — the bootstrap will refuse to install otherwise. The admin
# password is identical on every test DB created by this harness, so
# never expose this DB on a public network.
# Accepted values: 'mysql', 'mariadb', or anything starting with 'postgres'
# (e.g. 'postgres9'). See PKPContainer::getDatabaseDriverName.
OJS_DB_DRIVER=postgres9
OJS_DB_HOST=localhost
OJS_DB_USER=ojs
OJS_DB_PASSWORD=ojs
OJS_DB_NAME=ojs_test

# Files dir — must exist and be writable. Keep separate from your
# Cypress files dir so test submissions don't mingle.
OJS_FILES_DIR=../files-test

# Shared secret between the Playwright client (pkpApi.bootstrap) and the
# PHP server's TestModeGate. Arbitrary non-empty value; not a real secret,
# it just gates /api/v1/_test/* so dev requests can't hit it by accident.
TEST_API_KEY=playwright-test-key

# Admin creds — optional; installTest.php defaults to 'admin' /
# admin@test.local when these are unset.
# OJS_ADMIN_PASSWORD=admin
# OJS_ADMIN_EMAIL=admin@test.local

# Mailpit HTTP API base URL for the pkpMail fixture. Test-action mail
# (decisions, password resets, invitations sent through the UI) flows
# through OJS's SMTP transport (config.test.inc.php points it at
# 127.0.0.1:1025) into Mailpit; tests assert on it via this HTTP API.
# Scenario-seeding mail stays Mail::fake()'d inside the scenario
# controllers and never reaches Mailpit.
MAILPIT_URL=http://127.0.0.1:8025
