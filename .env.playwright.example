# Copy this file to .env.playwright and adjust values for your local
# environment. .env.playwright is gitignored.
#
# Only values that vary between developer setups live here. Mode
# switches like APPLICATION_ENV are hardcoded by Playwright, not set
# here — you should not need to touch them.

# Where the test server listens and tests connect.
PLAYWRIGHT_BASE_URL=http://127.0.0.1:8000

# Database — must exist and be empty. tools/installTest.php creates the
# schema. Keep the name distinct from your Cypress DB (cypress.env.json
# uses ojs_main_test) so the two suites can coexist.
OJS_DB_DRIVER=pgsql
OJS_DB_HOST=localhost
OJS_DB_USER=ojs
OJS_DB_PASSWORD=ojs
OJS_DB_NAME=ojs_test

# Files dir — must exist and be writable. Keep separate from your
# Cypress files dir so test submissions don't mingle.
OJS_FILES_DIR=../files-test

# Admin creds — optional; installTest.php defaults to 'admin' /
# admin@test.local when these are unset.
# OJS_ADMIN_PASSWORD=admin
# OJS_ADMIN_EMAIL=admin@test.local
